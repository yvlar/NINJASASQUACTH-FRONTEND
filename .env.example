# Variables d'environnement Supabase (copier dans `.env.local` pour le dev
# local ; en production, les poser dans le dashboard Vercel).
# La clé « publishable » est publique par conception (la sécurité repose sur
# la RLS) mais ne se committe jamais : elle vit dans l'environnement.
VITE_SUPABASE_URL=https://<ref-du-projet>.supabase.co
VITE_SUPABASE_ANON_KEY=<cle-publishable-du-projet>
